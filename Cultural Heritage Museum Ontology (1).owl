    <!-- ================= Classes (15) ================= -->
    <owl:Class rdf:about="#Museum">
        <definition>An institution that acquires, conserves, and exhibits objects of cultural, historical, or artistic value.</definition>
    </owl:Class>
    <owl:Class rdf:about="#Building">
        <definition>A physical structure that houses a museum and its galleries.</definition>
    </owl:Class>
    <owl:Class rdf:about="#Gallery">
        <definition>An exhibition space within a building where objects are displayed.</definition>
    </owl:Class>
    <owl:Class rdf:about="#Collection">
        <definition>An organised set of cultural objects held by a museum.</definition>
        <example>Renaissance Collection</example>
    </owl:Class>
    <owl:Class rdf:about="#Cultural_Object">
        <definition>Any item of cultural, historical, or artistic significance held by a museum.</definition>
    </owl:Class>
    <owl:Class rdf:about="#Artwork">
        <rdfs:subClassOf rdf:resource="#Cultural_Object"/>
        <owl:disjointWith rdf:resource="#Artifact"/>
        <definition>A cultural object created as a work of art, such as a painting or sculpture.</definition>
    </owl:Class>
    <owl:Class rdf:about="#Artifact">
        <rdfs:subClassOf rdf:resource="#Cultural_Object"/>
        <definition>A cultural object of historical or archaeological value made or used by people.</definition>
    </owl:Class>
    <owl:Class rdf:about="#Exhibition">
        <definition>A temporary or permanent public display of cultural objects.</definition>
    </owl:Class>
    <owl:Class rdf:about="#Person">
        <definition>A human being associated with the museum or its objects.</definition>
    </owl:Class>
    <owl:Class rdf:about="#Artist">
        <rdfs:subClassOf rdf:resource="#Person"/>
        <owl:disjointWith rdf:resource="#Curator"/>
        <owl:disjointWith rdf:resource="#Visitor"/>
        <definition>A person who creates artworks.</definition>
    </owl:Class>
    <owl:Class rdf:about="#Curator">
        <rdfs:subClassOf rdf:resource="#Person"/>
        <owl:disjointWith rdf:resource="#Visitor"/>
        <definition>A person responsible for managing collections and organising exhibitions.</definition>
    </owl:Class>
    <owl:Class rdf:about="#Visitor">
        <rdfs:subClassOf rdf:resource="#Person"/>
        <definition>A person who visits a museum or its exhibitions.</definition>
    </owl:Class>
    <owl:Class rdf:about="#Acquisition">
        <definition>An event by which a cultural object enters a museum collection.</definition>
    </owl:Class>
    <owl:Class rdf:about="#Restoration">
        <definition>A conservation event carried out to preserve or repair a cultural object.</definition>
    </owl:Class>
    <owl:Class rdf:about="#Historical_Period">
        <definition>A historical era or artistic period associated with cultural objects.</definition>
        <example>Renaissance</example>
    </owl:Class>

