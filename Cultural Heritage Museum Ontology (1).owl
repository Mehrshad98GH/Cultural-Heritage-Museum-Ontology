    <owl:NamedIndividual rdf:about="#National_Art_Museum">
        <rdf:type rdf:resource="#Museum"/>
        <museum_Name>National Art Museum</museum_Name>
        <founding_Year rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1885</founding_Year>
        <has_Collection rdf:resource="#Renaissance_Collection"/>
        <occupies_Building rdf:resource="#Heritage_Palace"/>
