    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Madonna_of_the_Garden">
        <rdf:type rdf:resource="#Artwork"/>
        <object_Title>Madonna of the Garden</object_Title>
        <inventory_Number>INV-00123</inventory_Number>
        <creation_Year rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1505</creation_Year>
        <material_Type>Oil on panel</material_Type>
        <dimensions>77 x 53 cm</dimensions>
        <created_By rdf:resource="#Elena_Visconti"/>
        <from_Period rdf:resource="#Renaissance"/>
        <acquired_Through rdf:resource="#Acquisition_2019"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Elena_Visconti">
        <rdf:type rdf:resource="#Artist"/>
        <person_Name>Elena Visconti</person_Name>
        <birth_Year rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1470</birth_Year>
        <death_Year rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1530</death_Year>
        <nationality>Italian</nationality>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Marco_Ricci">
        <rdf:type rdf:resource="#Curator"/>
        <person_Name>Marco Ricci</person_Name>
        <curator_Specialty>Renaissance Art</curator_Specialty>
        <curates_Exhibition rdf:resource="#Renaissance_Masters"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Anna_Bianchi">
        <rdf:type rdf:resource="#Visitor"/>
        <person_Name>Anna Bianchi</person_Name>
        <visits_Museum rdf:resource="#National_Art_Museum"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Renaissance_Masters">
        <rdf:type rdf:resource="#Exhibition"/>
        <exhibition_Title>Renaissance Masters</exhibition_Title>
        <start_Date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-01</start_Date>
        <end_Date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-07-31</end_Date>
        <displays_Object rdf:resource="#Madonna_of_the_Garden"/>
        <held_In_Gallery rdf:resource="#Gallery_G1"/>
        <curated_By rdf:resource="#Marco_Ricci"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Renaissance">
        <rdf:type rdf:resource="#Historical_Period"/>
        <period_Label>Renaissance</period_Label>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Acquisition_2019">
        <rdf:type rdf:resource="#Acquisition"/>
        <acquisition_Date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-06-15</acquisition_Date>
    </owl:NamedIndividual>
</rdf:RDF>

